# Port configuration: The port where the server will run. If not set, a default value (e.g., 3000) will be used.
PORT=3000

# Database connection: The URL or path to the database. In this case, it points to a SQLite database file.
DATABASE_URL=sqlite:./database/hellojob.db

# Secret key for JWT authentication: A strong and unique key used to sign and verify JWT tokens.
# Keep this value secret and avoid sharing it publicly.
JWT_SECRET=super@complex_key#123
